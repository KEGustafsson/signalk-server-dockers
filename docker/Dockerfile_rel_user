FROM ghcr.io/kegustafsson/signalk-server-base:latest

ARG TAG
USER node
RUN mkdir -p /home/node/.signalk/ \
  && mkdir -p /home/node/signalk/

WORKDIR /home/node/signalk

RUN corepack enable \
  && corepack prepare pnpm@10.6.3 --activate \
  && pnpm config set node-linker hoisted

RUN pnpm add signalk-server@$TAG \
  && mkdir -p node_modules/signalk-server/node_modules \
  && ln -s /home/node/signalk/node_modules/@signalk /home/node/signalk/node_modules/signalk-server/node_modules/@signalk \
  && rm -rf node_modules/@signalk/ \
  && mkdir -p node_modules/signalk-server/node_modules/@mxtommy/ \
  && cp -rf node_modules/@mxtommy/kip node_modules/signalk-server/node_modules/@mxtommy/ \
  && rm -rf node_modules/@mxtommy/;

COPY --chown=node docker/startup.sh startup.sh
RUN chmod +x startup.sh

EXPOSE 3000
ENV IS_IN_DOCKER=true
WORKDIR /home/node/.signalk
ENTRYPOINT ["/home/node/signalk/startup.sh"]
