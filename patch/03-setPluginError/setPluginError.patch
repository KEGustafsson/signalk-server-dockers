From 45270eadf89c6df39e56fac1e8feac25e6e52546 Mon Sep 17 00:00:00 2001
From: Karl-Erik Gustafsson <ke.gustafsson@gmail.com>
Date: Thu, 14 May 2026 17:34:18 +0300
Subject: [PATCH] fix: preserve provider status entry when clearing message
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

setPluginError("") (and other setters called with an empty message)
deleted the providerStatus entry outright. The Dashboard then lost the
statusType: 'plugin' marker used by getLinkType(), so the plugin moved
from Plugin Activity to Connections Activity until the next
setPluginStatus call.

Stop deleting on empty messages — entry removal belongs to the plugin
lifecycle (handled in appstore.js on uninstall), not to a status
setter. Mirror the existing lastError tracking by also remembering
lastStatus / lastStatusTimeStamp, so clearing an error restores the
previously reported status message instead of leaving the entry blank.
---
 src/index.ts | 51 ++++++++++++++++++++++++++++++++++++---------------
 1 file changed, 36 insertions(+), 15 deletions(-)

diff --git a/src/index.ts b/src/index.ts
index ee0379359..96c9a8768 100644
--- a/src/index.ts
+++ b/src/index.ts
@@ -210,27 +210,48 @@ class Server {
       type: string,
       statusType = 'provider'
     ) {
-      if (!statusMessage) {
-        delete app.providerStatus[providerId]
-        return
-      }
-
       if (_.isUndefined(app.providerStatus[providerId])) {
         app.providerStatus[providerId] = {}
       }
       const status = app.providerStatus[providerId]
+      const now = new Date().toISOString()
+      if (!statusMessage) {
+        if (type === 'error' && status.lastStatus) {
+          status.type = 'status'
+          status.message = status.lastStatus
+          status.timeStamp = status.lastStatusTimeStamp || now
+        } else {
+          status.type = type
+          status.message = ''
+          status.timeStamp = now
+        }
+        status.id = providerId
+        status.statusType = statusType
+      } else {
+        if (status.type === 'error' && status.message !== statusMessage) {
+          status.lastError = status.message
+          status.lastErrorTimeStamp = status.timeStamp
+        }
+        if (
+          type === 'error' &&
+          status.type === 'status' &&
+          status.message
+        ) {
+          status.lastStatus = status.message
+          status.lastStatusTimeStamp = status.timeStamp
+        }
 
-      if (status.type === 'error' && status.message !== statusMessage) {
-        status.lastError = status.message
-        status.lastErrorTimeStamp = status.timeStamp
-      }
-
-      status.type = type
-      status.id = providerId
-      status.statusType = statusType
-      status.timeStamp = new Date().toISOString()
+        status.type = type
+        status.id = providerId
+        status.statusType = statusType
+        status.timeStamp = now
+        status.message = statusMessage
 
-      status.message = statusMessage
+        if (type === 'status') {
+          status.lastStatus = statusMessage
+          status.lastStatusTimeStamp = status.timeStamp
+        }
+      }
 
       app.emit('serverevent', {
         type: 'PROVIDERSTATUS',
