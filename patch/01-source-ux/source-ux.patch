+        } else if (field === 'batteryInstance') {
+          // PGN 126208 targeting PGN 127508 (Battery Status):
+          // field order 1 = instance (8 bits, 0-252)
+          const instance = Number(value)
+          if (isNaN(instance) || instance < 0 || instance > 252) {
+            res.status(400).json({
