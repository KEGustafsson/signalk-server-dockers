+              pgn: 126208,
+              prio: 3,
+              dst,
+              fields: {
+                'Function Code': 'Command',
+                PGN: 127506,
+                priority: 8,
+                numberOfParameters: 1,
+                list: [{ parameter: 2, value: instance }]
+              }
+            })
