From 7965b3efb9104f4db394a1cb16d5b8464dd1f99d Mon Sep 17 00:00:00 2001
From: Karl-Erik Gustafsson <ke.gustafsson@gmail.com>
Date: Sat, 9 May 2026 22:48:48 +0300
Subject: [PATCH] Enable manifest generation in Vite config

Added manifest option to Vite configuration.
---
 packages/server-admin-ui/vite.config.ts | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/packages/server-admin-ui/vite.config.ts b/packages/server-admin-ui/vite.config.ts
index 5312370b8..a035fa0e1 100644
--- a/packages/server-admin-ui/vite.config.ts
+++ b/packages/server-admin-ui/vite.config.ts
@@ -130,7 +130,8 @@ export default defineConfig({
     sourcemap: true,
     target: 'es2023',
     assetsInlineLimit: 0, // Prevent inlining assets to allow server-side logo override
-    cssCodeSplit: false // Generate single CSS file to ensure it's always loaded
+    cssCodeSplit: false, // Generate single CSS file to ensure it's always loaded
+    manifest: true // Emit .vite/manifest.json so plugins can resolve hashed asset URLs
   },
   resolve: {
     alias: {
